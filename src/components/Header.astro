---
import { SITE_TITLE } from '../consts';
---

<header>
	<a class="site-title" href="/">{SITE_TITLE}</a>
	<nav>
		<a href="/about">About</a>
		<a href="https://t.me/+UAJhG1NG1jliNzJi" target="_blank" rel="noopener">Telegram</a>
	</nav>
</header>
<style>
	header {
		max-width: 640px;
		margin: 0 auto;
		padding: 2em 1.5em 0;
		display: flex;
		justify-content: space-between;
		align-items: baseline;
	}
	.site-title {
		font-size: 1.2em;
		font-weight: 700;
		text-decoration: none;
		color: var(--text);
	}
	nav {
		display: flex;
		gap: 1.25em;
	}
	nav a {
		color: var(--text-light);
		text-decoration: none;
		font-size: 0.95em;
	}
	nav a:hover {
		color: var(--text);
	}
	@media (max-width: 640px) {
		header {
			padding: 1.5em 1em 0;
		}
	}
</style>
